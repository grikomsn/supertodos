# Vite (client) — from Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key

# Express server only — never use VITE_ prefix for these (except VITE_SUPABASE_URL is read for JWKS if SUPABASE_URL unset)
PORT=3000
# Same project URL as above; used to fetch JWKS for ES256 access-token verification
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Settings → Database → Connection string (URI), Session mode recommended for serverless-friendly pooling
DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
